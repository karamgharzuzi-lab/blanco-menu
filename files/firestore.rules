rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // The menu. Anyone can READ it (customers). Only YOU can change it.
    match /dishes/{id} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.email == "admin@blanco.com";
    }
  }
}
