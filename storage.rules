rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Dish photos. Anyone can VIEW them. Only YOU can upload/replace.
    match /dishes/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.email == "admin@blanco.com";
    }
  }
}
